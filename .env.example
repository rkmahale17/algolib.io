# Backend URLs
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_APP_ENV="development" # options: development, qa, production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# PostHog
NEXT_PUBLIC_PUBLIC_POSTHOG_TOKEN=""
NEXT_PUBLIC_PUBLIC_POSTHOG_HOST=""

# Secrets (Server-side only, do NOT use NEXT_PUBLIC_)
GEMINI_API_KEY=""
SEND_EMAIL_HOOK_SECRET=""

# Lemon Squeezy — add these as Supabase Edge Function secrets (NOT in .env)
# Go to: Supabase Dashboard → Edge Functions → Manage secrets
#
# Live (production)
# LS_API_KEY=live_...
# LS_STORE_ID=<your_store_id>
# LS_VARIANT_ID_3MONTHLY=<variant_id>
# LS_VARIANT_ID_6MONTHLY=<variant_id>
# LS_VARIANT_ID_YEARLY=<variant_id>
# LS_WEBHOOK_SECRET=<your_signing_secret>
#
# Test mode (local / staging)
# LS_TEST_API_KEY=test_...
# LS_TEST_STORE_ID=<test_store_id>
# LS_TEST_VARIANT_ID_3MONTHLY=<test_variant_id>
# LS_TEST_VARIANT_ID_6MONTHLY=<test_variant_id>
# LS_TEST_VARIANT_ID_YEARLY=<test_variant_id>
